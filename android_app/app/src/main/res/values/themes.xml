<resources xmlns:tools="http://tools.android.com/security">
    <!-- Light Theme -->
    <style name="Theme.OutpassSystem" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:windowBackground">@color/bgLight</item>
        <item name="android:statusBarColor">@color/bgLight</item>
        <item name="android:navigationBarColor">@color/bgLight</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.OutpassSystem.NoActionBar" parent="Theme.OutpassSystem">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>
